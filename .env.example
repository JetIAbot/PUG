# PUG - Plantilla de configuración local
# Copiar como .env y ajustar valores
# NUNCA hacer commit de credenciales reales

# Entorno
APP_ENV=development
DEBUG=True
DEMO_MODE=True

# Firebase
FIREBASE_CREDENTIALS_PATH=firebase.json

# Portal universitario
USE_REAL_PORTAL=False
PORTAL_URL=https://segreteria.unigre.it
HEADLESS_MODE=True

# Logging
LOG_LEVEL=INFO
AUTO_CLEANUP=True
LOG_MAX_DAYS=7

# Seguridad
MASK_CREDENTIALS=True
LOG_SENSITIVE_DATA=False
